<?xml version="1.0"?>

<robot name="aegis_three_joint_arm">

    <!-- ================================================== -->
    <!-- BASE                                               -->
    <!-- ================================================== -->

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.15"/>
            <geometry>
                <cylinder radius="0.16" length="0.30"/>
            </geometry>
            <material name="dark">
                <color rgba="0.12 0.15 0.20 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0.15"/>
            <geometry>
                <cylinder radius="0.16" length="0.30"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0 0 0.15"/>
            <mass value="5.0"/>
            <inertia
                ixx="0.05"
                ixy="0"
                ixz="0"
                iyy="0.05"
                iyz="0"
                izz="0.06"/>
        </inertial>
    </link>

    <!-- ================================================== -->
    <!-- LINK 1                                             -->
    <!-- ================================================== -->

    <link name="link_1">
        <visual>
            <origin xyz="0.275 0 0"/>
            <geometry>
                <box size="0.55 0.10 0.10"/>
            </geometry>
            <material name="blue">
                <color rgba="0.10 0.45 0.90 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.275 0 0"/>
            <geometry>
                <box size="0.55 0.10 0.10"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.275 0 0"/>
            <mass value="1.5"/>
            <inertia
                ixx="0.003"
                ixy="0"
                ixz="0"
                iyy="0.039"
                iyz="0"
                izz="0.039"/>
        </inertial>
    </link>

    <joint name="joint_1" type="revolute">
        <parent link="base_link"/>
        <child link="link_1"/>
        <origin xyz="0 0 0.36"/>
        <axis xyz="0 0 1"/>
        <limit
            lower="-2.70"
            upper="2.70"
            effort="100"
            velocity="2.0"/>
        <dynamics damping="0.15" friction="0.04"/>
    </joint>

    <!-- ================================================== -->
    <!-- LINK 2                                             -->
    <!-- ================================================== -->

    <link name="link_2">
        <visual>
            <origin xyz="0.225 0 0"/>
            <geometry>
                <box size="0.45 0.09 0.09"/>
            </geometry>
            <material name="orange">
                <color rgba="0.95 0.45 0.08 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.225 0 0"/>
            <geometry>
                <box size="0.45 0.09 0.09"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.225 0 0"/>
            <mass value="1.0"/>
            <inertia
                ixx="0.002"
                ixy="0"
                ixz="0"
                iyy="0.018"
                iyz="0"
                izz="0.018"/>
        </inertial>
    </link>

    <joint name="joint_2" type="revolute">
        <parent link="link_1"/>
        <child link="link_2"/>
        <origin xyz="0.55 0 0"/>
        <axis xyz="0 0 1"/>
        <limit
            lower="-2.70"
            upper="2.70"
            effort="80"
            velocity="2.0"/>
        <dynamics damping="0.12" friction="0.04"/>
    </joint>

    <!-- ================================================== -->
    <!-- LINK 3                                             -->
    <!-- ================================================== -->

    <link name="link_3">
        <visual>
            <origin xyz="0.19 0 0"/>
            <geometry>
                <box size="0.38 0.08 0.08"/>
            </geometry>
            <material name="green">
                <color rgba="0.15 0.75 0.35 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.19 0 0"/>
            <geometry>
                <box size="0.38 0.08 0.08"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.19 0 0"/>
            <mass value="0.7"/>
            <inertia
                ixx="0.001"
                ixy="0"
                ixz="0"
                iyy="0.009"
                iyz="0"
                izz="0.009"/>
        </inertial>
    </link>

    <joint name="joint_3" type="revolute">
        <parent link="link_2"/>
        <child link="link_3"/>
        <origin xyz="0.45 0 0"/>
        <axis xyz="0 0 1"/>
        <limit
            lower="-2.70"
            upper="2.70"
            effort="60"
            velocity="2.0"/>
        <dynamics damping="0.10" friction="0.03"/>
    </joint>

    <!-- ================================================== -->
    <!-- END EFFECTOR                                       -->
    <!-- ================================================== -->

    <link name="end_effector">
        <visual>
            <origin xyz="0.05 0 0"/>
            <geometry>
                <box size="0.10 0.16 0.07"/>
            </geometry>
            <material name="gripper">
                <color rgba="0.75 0.75 0.78 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0.05 0 0"/>
            <geometry>
                <box size="0.10 0.16 0.07"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.05 0 0"/>
            <mass value="0.25"/>
            <inertia
                ixx="0.0006"
                ixy="0"
                ixz="0"
                iyy="0.0006"
                iyz="0"
                izz="0.0006"/>
        </inertial>
    </link>

    <joint name="end_effector_joint" type="fixed">
        <parent link="link_3"/>
        <child link="end_effector"/>
        <origin xyz="0.38 0 0"/>
    </joint>

</robot>